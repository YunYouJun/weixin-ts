# Optional: pre-existing bot token — skip QR login
# WEIXIN_BOT_TOKEN=your-bot-token-here

# Optional: custom API base URL
# WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com

# Required: DeepSeek API key
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Optional: model name (default: deepseek-v4-flash)
# DEEPSEEK_MODEL=deepseek-v4-flash

# Optional: max conversation history per user (default: 20)
# DEEPSEEK_MAX_HISTORY=20

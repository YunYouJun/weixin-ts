{
  "name": "@weixin-ts/cdn",
  "type": "module",
  "version": "0.1.0",
  "description": "WeChat CDN upload/download with AES-ECB encryption (cross-platform WebCrypto)",
  "author": "YunYouJun",
  "license": "MIT",
  "funding": "https://github.com/sponsors/YunYouJun",
  "homepage": "https://weixin-ts.yunyoujun.cn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YunYouJun/weixin-ts.git",
    "directory": "packages/cdn"
  },
  "bugs": "https://github.com/YunYouJun/weixin-ts/issues",
  "keywords": [
    "weixin",
    "wechat",
    "cdn",
    "aes-ecb",
    "encryption"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "prepublishOnly": "nr build",
    "start": "tsx src/index.ts"
  }
}
